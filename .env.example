# Copy to .env and fill in at least one LLM provider key.
# docker compose loads .env automatically for variable substitution.

# Web UI
OPENCLIP_PORT=8502

# Container timezone (job timestamps / logs). Default matches China local time.
# TZ=Asia/Shanghai

# Optional Debian apt mirror for faster/more reliable Docker builds
# APT_MIRROR=mirrors.aliyun.com

# LLM providers (set at least one)
QWEN_API_KEY=
OPENROUTER_API_KEY=
GLM_API_KEY=
MINIMAX_API_KEY=

# Optional OpenAI-compatible endpoint
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=
CUSTOM_OPENAI_MODEL=

# Optional: speaker diarization (requires speakers extra in a custom image)
HUGGINGFACE_TOKEN=
